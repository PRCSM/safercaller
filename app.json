{
  "expo": {
    "name": "SAFERCALLER",
    "slug": "safercaller",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./src/assets/icons/icon.png",
    "splash": {
      "image": "./src/assets/icons/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.safercaller.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "SAFERCALLER uses the camera for identity verification and profile photos.",
        "NSMicrophoneUsageDescription": "SAFERCALLER uses the microphone for the AI Receptionist feature.",
        "NSPhotoLibraryUsageDescription": "SAFERCALLER accesses your photos for profile pictures and proof uploads.",
        "NSFaceIDUsageDescription": "SAFERCALLER uses biometrics for secure login.",
        "NSLocationWhenInUseUsageDescription": "SAFERCALLER uses your location to show nearby listings."
      }
    },
    "android": {
      "package": "com.safercaller.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icons/icon.png",
        "backgroundColor": "#0066FF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALL_LOG",
        "android.permission.WRITE_CALL_LOG",
        "android.permission.PROCESS_OUTGOING_CALLS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./src/assets/icons/icon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-camera",
        {
          "cameraPermission": "SAFERCALLER uses the camera for identity verification."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SAFERCALLER accesses photos for profile pictures and proof uploads."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "SAFERCALLER uses the microphone for the AI Receptionist feature."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "SAFERCALLER uses Face ID for secure login."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SAFERCALLER uses your location to show nearby listings.",
          "locationWhenInUsePermission": "SAFERCALLER uses your location to show nearby listings."
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b75a4565-bb9a-45ee-9d5b-93823f9e78c5"
      }
    },
    "owner": "paikhomba"
  }
}
